{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/mtg-scanner/recognition-response.schema.json",
  "title": "RecognitionResponse",
  "type": "object",
  "required": ["cards"],
  "properties": {
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["confidence"],
        "properties": {
          "title": { "type": ["string", "null"] },
          "edition": { "type": ["string", "null"] },
          "collector_number": { "type": ["string", "null"] },
          "foil": { "type": ["boolean", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "notes": { "type": ["string", "null"] },
          "edition_notes": { "type": ["string", "null"] },
          "foil_type": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "none",
                  "rainbow_traditional",
                  "pre_modern_shootingstar",
                  "etched",
                  "textured",
                  "confetti",
                  "ripple",
                  "galaxy",
                  "halo",
                  "raised",
                  "unknown"
                ]
              },
              { "type": "null" }
            ]
          },
          "foil_evidence": {
            "anyOf": [
              { "type": "array", "items": { "type": "string" } },
              { "type": "null" }
            ]
          },
          "list_reprint": {
            "anyOf": [
              { "type": "string", "enum": ["yes", "no", "possible"] },
              { "type": "null" }
            ]
          },
          "list_symbol_visible": { "type": ["boolean", "null"] },
          "border_color": {
            "anyOf": [
              { "type": "string", "enum": ["white", "black", "unknown"] },
              { "type": "null" }
            ]
          },
          "copyright_line": { "type": ["string", "null"] },
          "promo_text": { "type": ["string", "null"] },
          "set_code": { "type": ["string", "null"] },
          "rarity": { "type": ["string", "null"] },
          "type_line": { "type": ["string", "null"] },
          "oracle_text": { "type": ["string", "null"] },
          "mana_cost": { "type": ["string", "null"] },
          "power": { "type": ["string", "null"] },
          "toughness": { "type": ["string", "null"] },
          "loyalty": { "type": ["string", "null"] },
          "defense": { "type": ["string", "null"] },
          "scryfall_id": { "type": ["string", "null"] },
          "image_url": { "type": ["string", "null"] },
          "set_symbol_url": { "type": ["string", "null"] },
          "card_kingdom_url": { "type": ["string", "null"] },
          "card_kingdom_foil_url": { "type": ["string", "null"] },
          "color_identity": { "type": ["string", "null"] },
          "crop_image_data": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
