# LLM Provider Selection
# Options: mock | openai | moonshot | anthropic
MTG_SCANNER_LLM_PROVIDER=mock

# Generic LLM Settings (optional shared defaults across providers)
MTG_SCANNER_LLM_API_KEY=
# Leave model/base URL blank to use each provider's built-in defaults.
MTG_SCANNER_LLM_MODEL=
MTG_SCANNER_LLM_BASE_URL=
MTG_SCANNER_LLM_TIMEOUT_SECONDS=30
# Response mode: json_schema (recommended), json_mode, raw
# Note: Moonshot auto-downgrades json_schema to json_mode
MTG_SCANNER_LLM_RESPONSE_MODE=json_schema

# Provider-Specific Overrides (optional - use to override generic settings)
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=

# Moonshot
MOONSHOT_API_KEY=
MOONSHOT_MODEL=
MOONSHOT_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=

# API bind settings for local development.
MTG_SCANNER_API_HOST=127.0.0.1
MTG_SCANNER_API_PORT=8000

# Enable multi-card detection (default: true)
MTG_SCANNER_ENABLE_MULTI_CARD=true

# Maximum number of per-card recognition calls to run concurrently
# after all crops have been prepared (default: 4)
MTG_SCANNER_MAX_CONCURRENT_RECOGNITIONS=4

# Optional artifact output override.
# MTG_SCANNER_ARTIFACTS_DIR=/absolute/path/to/artifacts

# MTGJSON-backed validation settings.
MTG_SCANNER_ENABLE_MTG_VALIDATION=true
MTG_SCANNER_MTGJSON_DB_PATH=services/api/data/mtgjson/mtgjson.sqlite
MTG_SCANNER_MTGJSON_SOURCE_PATH=tmp/AllPrintings.json
MTG_SCANNER_MTGJSON_MAX_FUZZY_CANDIDATES=10

# LLM-assisted correction: when validation returns needs_correction, re-query
# the LLM with the constrained candidate list to pick the correct printing.
MTG_SCANNER_ENABLE_LLM_CORRECTION=true
MTG_SCANNER_CORRECTION_PROMPT_VERSION=card-correction.md

# LLM pricing refresh.
# Set interval > 0 to enable a background loop that refreshes pricing from
# pydantic/genai-prices every N hours (0 = disabled, recommended default).
# Run `make api-update-pricing` to refresh manually without restarting the server.
MTG_SCANNER_PRICING_REFRESH_INTERVAL_HOURS=0

# Admin API token. When set, mounts POST /api/v1/admin/pricing/refresh.
# Requires header: X-Admin-Token: <token>. Leave blank to disable the endpoint.
# MTG_SCANNER_ADMIN_TOKEN=

# Logging settings. Log level can be DEBUG, INFO, WARNING, ERROR, or CRITICAL.
MTG_SCANNER_LOG_LEVEL=INFO

# Card Kingdom pricing. Run `make api-import-ck-prices` to populate the DB.
MTG_SCANNER_ENABLE_CK_PRICES=true
MTG_SCANNER_CK_PRICES_DB_PATH=services/api/data/ck_prices/ck_prices.sqlite
MTG_SCANNER_CK_PRICES_URL=https://www.cardkingdom.com/assets/json/product_catalog.json
