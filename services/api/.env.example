MTG_SCANNER_RECOGNIZER_PROVIDER=mock

# API bind settings for local development.
MTG_SCANNER_API_HOST=127.0.0.1
MTG_SCANNER_API_PORT=8000

# Enable multi-card detection (default: true)
MTG_SCANNER_ENABLE_MULTI_CARD=true

# Maximum number of per-card recognition calls to run concurrently
# after all crops have been prepared (default: 4)
MTG_SCANNER_MAX_CONCURRENT_RECOGNITIONS=4

# OpenAI provider settings. Only required when
# MTG_SCANNER_RECOGNIZER_PROVIDER=openai.
OPENAI_API_KEY=
MTG_SCANNER_OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
MTG_SCANNER_OPENAI_TIMEOUT_SECONDS=30
MTG_SCANNER_OPENAI_RESPONSE_MODE=json_schema

# Optional artifact output override.
# MTG_SCANNER_ARTIFACTS_DIR=/absolute/path/to/artifacts

# MTGJSON-backed validation settings.
MTG_SCANNER_ENABLE_MTG_VALIDATION=true
MTG_SCANNER_MTGJSON_DB_PATH=services/api/data/mtgjson/mtgjson.sqlite
MTG_SCANNER_MTGJSON_SOURCE_PATH=tmp/AllPrintings.json
MTG_SCANNER_MTGJSON_MAX_FUZZY_CANDIDATES=10

# Card Kingdom pricing. Run `make api-import-ck-prices` to populate the DB.
MTG_SCANNER_ENABLE_CK_PRICES=true
MTG_SCANNER_CK_PRICES_DB_PATH=services/api/data/ck_prices/ck_prices.sqlite
MTG_SCANNER_CK_PRICES_URL=https://www.cardkingdom.com/assets/json/singles_prices.json
